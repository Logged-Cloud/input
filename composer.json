{
    "name": "logged-cloud/input",
    "description": "Alpine-driven free-form input components for Laravel + Livewire · masks, passwords, OTP boxes, auto-resizing textareas, tags, autocomplete. Companion to logged-cloud/select.",
    "keywords": ["laravel", "livewire", "alpine", "input", "form", "mask", "otp", "password", "tags"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "LoggedCloud\\Input\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LoggedCloud\\Input\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LoggedCloud\\Input\\InputServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
